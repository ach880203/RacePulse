# =============================================================================
# RacePulse 루트 .gitignore
# =============================================================================

# 환경변수 파일 - 절대 커밋 금지
.env
.env.local
.env.*.local
**/.env
**/.env.local

# 압축 파일
*.zip
*.tar.gz

# Claude 내부 파일
.claude/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# 로그
*.log
*.err
*.out
logs/

# Python 가상환경
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Node
node_modules/
dist/
.next/

# Gradle
.gradle/
build/

# 런타임 파일
bootrun.err
bootrun.out

# ML 서버 스크립트 실행 로그 — 로컬 실행 결과물이라 커밋하면 재현성과 리뷰 품질이 떨어집니다.
racepulse/ml-server/scripts/bulk_stdout.txt
racepulse/ml-server/scripts/bulk_stderr.txt
racepulse/ml-server/scripts/nightly_log.txt

# Task Scheduler 관련 스크립트 — 작업 스케줄러 경로와 권한은 PC마다 달라 저장소에서 제외합니다.
racepulse/ml-server/scripts/fix_scheduler_admin.ps1
